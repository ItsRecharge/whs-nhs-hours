# --- Required ---

# SQLite database file (relative to prisma/ directory)
DATABASE_URL="file:../data/app.db"

# Secret for signing session cookies. Generate with: openssl rand -base64 32
SESSION_SECRET=""

# Public base URL of the app (used to build links in emails)
APP_URL="http://localhost:3000"

# --- Seed / bootstrap (used by `npm run db:seed`) ---

# The first officer account, created pre-verified so you can log in immediately
BOOTSTRAP_OFFICER_EMAIL=""
BOOTSTRAP_OFFICER_PASSWORD=""
BOOTSTRAP_OFFICER_NAME="Chapter Officer"

# Set to "true" to also seed demo events and a demo member (local dev only)
SEED_DEMO="false"

# --- Integrations (optional) ---
# Email + Sheets can also be configured in-app at /officer/integrations (stored in
# the DB, secrets AES-GCM encrypted). These env vars are the FALLBACK used when the
# DB config is empty. NOTE: the encryption key is derived from SESSION_SECRET — if you
# rotate SESSION_SECRET, any DB-stored secrets become unreadable and fall back to env.

# --- Operations console (optional, off by default) ---
# Set to "true" to enable the browser-based operations console.
OPS_CONSOLE_ENABLED="false"
# Comma-separated allowlist of officer emails that may unlock the console.
OPS_ADMIN_EMAILS=""

# --- Email (optional — app runs without it; emails become no-ops) ---

# Gmail account used for ALL outgoing mail (verification + notifications).
# Requires 2-Step Verification + an App Password (https://myaccount.google.com/apppasswords)
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# --- Google Sheets hours backup (optional — no-ops when unset) ---

# Spreadsheet ID from the sheet URL; share the sheet with the service account email
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
# Base64-encoded private key from the service account JSON (key field).
# Encode with: node -e "console.log(Buffer.from(process.argv[1]).toString('base64'))" "$(jq -r .private_key sa.json)"
GOOGLE_SERVICE_ACCOUNT_KEY=""
